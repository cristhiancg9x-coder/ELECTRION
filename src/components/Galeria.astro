---
import { Image } from "astro:assets";

import fotoTablero from "../assets/tablero-industrial.jpeg";
import fotoPozo from "../assets/pozo-tierra.jpeg";
import fotoLed from "../assets/iluminacion-led.jpeg";
import fotoCasa from "../assets/cableado-casa.jpeg";
---

<section id="portfolio" class="py-16 px-4">
  <div class="max-w-6xl mx-auto text-center">
    <h2 class="text-3xl md:text-4xl font-bold mb-2 text-white drop-shadow-md">
      Portafolio
    </h2>
    <p class="text-lg text-gray-300 mb-12">
      Nuestros Proyectos Recientes. Calidad y seguridad certificada en cada
      instalación.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 md:gap-8">
      <div
        class="group relative overflow-hidden rounded-2xl aspect-[4/3] bg-black/20 border border-white/10 shadow-[0_8px_20px_rgba(0,0,0,0.3)] hover:border-electrion-accent hover:shadow-[0_15px_30px_rgba(0,0,0,0.4)] cursor-pointer transition-all duration-300"
      >
        <Image
          src={fotoTablero}
          alt="Mantenimiento de tablero eléctrico industrial en Moquegua"
          width={600}
          quality="mid"
          class="w-full h-full object-cover transition-transform duration-[600ms] ease-[cubic-bezier(0.25,0.46,0.45,0.94)] group-hover:scale-110"
        />
        <div
          class="absolute bottom-0 left-0 w-full p-6 text-left bg-gradient-to-t from-black/90 via-black/60 to-transparent translate-y-3 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300"
        >
          <h3 class="text-xl font-bold text-electrion-accent mb-1">
            Tablero Industrial
          </h3>
          <p class="text-sm text-slate-200">Mantenimiento y peinado</p>
        </div>
      </div>

      <div
        class="group relative overflow-hidden rounded-2xl aspect-[4/3] bg-black/20 border border-white/10 shadow-[0_8px_20px_rgba(0,0,0,0.3)] hover:border-electrion-accent hover:shadow-[0_15px_30px_rgba(0,0,0,0.4)] cursor-pointer transition-all duration-300"
      >
        <Image
          src={fotoPozo}
          alt="Instalación de Pozo a Tierra en Cayma"
          width={600}
          quality="mid"
          class="w-full h-full object-cover transition-transform duration-[600ms] ease-[cubic-bezier(0.25,0.46,0.45,0.94)] group-hover:scale-110"
        />
        <div
          class="absolute bottom-0 left-0 w-full p-6 text-left bg-gradient-to-t from-black/90 via-black/60 to-transparent translate-y-3 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300"
        >
          <h3 class="text-xl font-bold text-electrion-accent mb-1">Pozo a Tierra</h3>
          <p class="text-sm text-slate-200">Certificación INDECI</p>
        </div>
      </div>

      <div
        class="group relative overflow-hidden rounded-2xl aspect-[4/3] bg-black/20 border border-white/10 shadow-[0_8px_20px_rgba(0,0,0,0.3)] hover:border-electrion-accent hover:shadow-[0_15px_30px_rgba(0,0,0,0.4)] cursor-pointer transition-all duration-300"
      >
        <Image
          src={fotoLed}
          alt="Iluminación LED oficinas"
          width={600}
          quality="mid"
          class="w-full h-full object-cover transition-transform duration-[600ms] ease-[cubic-bezier(0.25,0.46,0.45,0.94)] group-hover:scale-110"
        />
        <div
          class="absolute bottom-0 left-0 w-full p-6 text-left bg-gradient-to-t from-black/90 via-black/60 to-transparent translate-y-3 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300"
        >
          <h3 class="text-xl font-bold text-electrion-accent mb-1">
            Iluminación LED
          </h3>
          <p class="text-sm text-slate-200">Ahorro de energía</p>
        </div>
      </div>

      <div
        class="group relative overflow-hidden rounded-2xl aspect-[4/3] bg-black/20 border border-white/10 shadow-[0_8px_20px_rgba(0,0,0,0.3)] hover:border-electrion-accent hover:shadow-[0_15px_30px_rgba(0,0,0,0.4)] cursor-pointer transition-all duration-300"
      >
        <Image
          src={fotoCasa}
          alt="Cableado residencial seguro"
          width={600}
          quality="mid"
          class="w-full h-full object-cover transition-transform duration-[600ms] ease-[cubic-bezier(0.25,0.46,0.45,0.94)] group-hover:scale-110"
        />
        <div
          class="absolute bottom-0 left-0 w-full p-6 text-left bg-gradient-to-t from-black/90 via-black/60 to-transparent translate-y-3 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-300"
        >
          <h3 class="text-xl font-bold text-electrion-accent mb-1">Residencial</h3>
          <p class="text-sm text-slate-200">Cableado libre de halógenos</p>
        </div>
      </div>
    </div>
  </div>
</section>

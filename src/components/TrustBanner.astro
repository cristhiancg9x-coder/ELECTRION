---
// src/components/TrustBanner.astro
---

<div class="bg-electrion-blue border-b border-white/10 py-6">
  <div class="container mx-auto px-4 max-w-7xl">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 text-center">
      <div
        class="flex flex-col items-center justify-center p-2 reveal-on-scroll opacity-0 translate-y-4 transition-all duration-500"
      >
        <i class="fas fa-shield-alt text-3xl text-electrion-accent mb-2"></i>
        <span class="text-white font-medium text-sm md:text-base"
          >Garantía Real</span
        >
      </div>

      <div
        class="flex flex-col items-center justify-center p-2 reveal-on-scroll opacity-0 translate-y-4 transition-all duration-500 delay-100"
      >
        <i class="fas fa-certificate text-3xl text-electrion-accent mb-2"></i>
        <span class="text-white font-medium text-sm md:text-base"
          >Técnicos Especialistas</span
        >
      </div>

      <div
        class="flex flex-col items-center justify-center p-2 reveal-on-scroll opacity-0 translate-y-4 transition-all duration-500 delay-200"
      >
        <i class="fas fa-clock text-3xl text-electrion-accent mb-2"></i>
        <span class="text-white font-medium text-sm md:text-base"
          >Atención 24/7 Urgencias</span
        >
      </div>

      <div
        class="flex flex-col items-center justify-center p-2 reveal-on-scroll opacity-0 translate-y-4 transition-all duration-500 delay-300"
      >
        <i class="fas fa-file-invoice-dollar text-3xl text-electrion-accent mb-2"></i>
        <span class="text-white font-medium text-sm md:text-base"
          >Emitimos Factura / Boleta</span
        >
      </div>
    </div>
  </div>
</div>

---
/**
 * @page Landing Local (SEO Local)
 * @description Páginas de aterrizaje específicas para distritos/zonas.
 * Adaptado a Electrion.
 */
import Layout from "../../layouts/Layout.astro";
import { zonas } from "../../data/zonas.js";

export function getStaticPaths() {
  return zonas.map((zona) => ({
    params: { lugar: zona.slug },
    props: { zona },
  }));
}

const { zona } = Astro.props;
---

<Layout title={`${zona.titulo} | Servicio Rápido 24/7`}>
  <main class="min-h-screen pt-20 pb-16">
    <section
      class="bg-electrion-dark border-b border-white/10 text-white py-16 px-4 text-center"
    >
      <div class="max-w-4xl mx-auto">
        <h1
          class="text-4xl md:text-5xl font-bold mb-4 text-electrion-accent drop-shadow-md"
        >
          ⚡ {zona.titulo}
        </h1>
        <p class="text-xl text-slate-300 max-w-2xl mx-auto mb-10">
          {zona.desc}
        </p>

        <div
          class="bg-white text-electrion-dark p-8 rounded-2xl max-w-lg mx-auto shadow-2xl relative overflow-hidden"
        >
          <div class="absolute top-0 left-0 w-full h-1 bg-electrion-accent"></div>
          <p class="text-lg md:text-xl font-bold mb-2">
            🚨 ¿Estás en {zona.nombre} y necesitas ayuda urgente?
          </p>
          <p class="text-slate-600 mb-6 font-medium">
            Estamos cerca de tu zona. Atendemos emergencias eléctricas las 24
            horas del día.
          </p>

          <a
            href={`https://wa.me/51999999999?text=Hola,%20necesito%20un%20electricista%20en%20${zona.nombre}`}
            class="inline-block bg-green-500 hover:bg-green-600 active:scale-95 text-white font-bold py-3 px-8 rounded-full shadow-lg hover:shadow-[0_0_15px_rgba(34,197,94,0.5)] transition-all duration-300"
            target="_blank"
          >
            <i class="fa-brands fa-whatsapp mr-2 text-xl align-middle"></i>
            Pedir Técnico en {zona.nombre}
          </a>
        </div>
      </div>
    </section>

    <section class="max-w-3xl mx-auto py-16 px-4">
      <h2
        class="text-3xl font-bold text-white mb-8 pb-2 border-b-2 border-electrion-accent inline-block drop-shadow-md"
      >
        Servicios disponibles en {zona.nombre}
      </h2>

      <ul class="space-y-4 mb-12">
        <li
          class="flex items-center text-lg text-slate-200 bg-white/5 p-4 rounded-xl border border-white/10"
        >
          <span class="text-electrion-accent text-2xl mr-4">✅</span> Reparación de Cortocircuitos
          y Apagones.
        </li>
        <li
          class="flex items-center text-lg text-slate-200 bg-white/5 p-4 rounded-xl border border-white/10"
        >
          <span class="text-electrion-accent text-2xl mr-4">✅</span> Instalación de Duchas
          Eléctricas (Rapiduchas).
        </li>
        <li
          class="flex items-center text-lg text-slate-200 bg-white/5 p-4 rounded-xl border border-white/10"
        >
          <span class="text-electrion-accent text-2xl mr-4">✅</span> Mantenimiento de Pozo
          a Tierra (Certificado).
        </li>
        <li
          class="flex items-center text-lg text-slate-200 bg-white/5 p-4 rounded-xl border border-white/10"
        >
          <span class="text-electrion-accent text-2xl mr-4">✅</span> Cableado de casas y
          departamentos.
        </li>
      </ul>

      <h3 class="text-2xl font-bold text-electrion-accent mb-4 drop-shadow-md">
        ¿Por qué elegirnos en {zona.nombre}?
      </h3>
      <p
        class="text-lg text-slate-300 leading-relaxed bg-white/5 p-6 rounded-xl border border-white/10"
      >
        Conocemos los problemas eléctricos típicos de <strong
          class="text-white text-xl">{zona.nombre}</strong
        >. No cobramos viáticos excesivos porque estamos en la zona.
        Garantizamos una llegada rápida, seguridad total y emisión de
        comprobantes autorizados.
      </p>
    </section>
  </main>
</Layout>

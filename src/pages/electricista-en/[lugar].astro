---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";
import { Image } from "astro:assets";

export async function getStaticPaths() {
  const lugares = await getCollection("lugares");
  return lugares.map((lugar) => ({
    params: { lugar: lugar.slug },
    props: { lugar },
  }));
}

const { lugar } = Astro.props;
const servicios = await getCollection("servicios");
---

<Layout
  title={`Electricistas en ${lugar.data.name} | ELECTRION`}
  description={`Servicios eléctricos 24 horas en ${lugar.data.name}, Moquegua. Instalaciones residenciales, tableros y pozos a tierra. Cotiza ahora en ELECTRION.`}
>
  <!-- Hero Geo-Optimizado -->
  <section class="bg-electrion-dark text-white py-20 relative overflow-hidden">
    <div class="absolute inset-0 z-0 opacity-10 pointer-events-none">
      <svg class="w-full h-full" xmlns="http://www.w3.org/2000/svg">
        <defs>
          <pattern
            id="circuit-pattern-small"
            x="0"
            y="0"
            width="100"
            height="100"
            patternUnits="userSpaceOnUse"
          >
            <path
              d="M10,50 L20,50 L25,55 L25,75 L30,80 L70,80 L75,75 L75,25 L80,20 L90,20"
              fill="none"
              stroke="#2563eb"
              stroke-width="1"
              stroke-linecap="round"
              stroke-linejoin="round"></path>
          </pattern>
        </defs>
        <rect width="100%" height="100%" fill="url(#circuit-pattern-small)"
        ></rect>
      </svg>
    </div>
    <div class="container mx-auto px-4 text-center relative z-10">
      <span
        class="text-electrion-accent font-semibold tracking-wider uppercase text-sm mb-4 block"
      >
        Cobertura en tu Zona
      </span>
      <h1
        class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6 drop-shadow-lg"
      >
        Electricista en <span class="text-electrion-accent"
          >{lugar.data.name}</span
        >
      </h1>
      <p class="text-xl md:text-2xl text-slate-300 max-w-3xl mx-auto">
        {lugar.data.description}
      </p>

      <div class="mt-8 flex justify-center gap-4">
        <a
          href={`https://wa.me/51951413458?text=Hola,%20necesito%20un%20electricista%20en%20${encodeURIComponent(lugar.data.name)}`}
          target="_blank"
          class="bg-green-500 hover:bg-green-600 text-white font-bold py-4 px-8 rounded-xl transition duration-300 shadow-lg flex items-center justify-center"
        >
          <i class="fab fa-whatsapp text-xl mr-2"></i> Solicitar Asistencia
        </a>
      </div>
    </div>
  </section>

  <!-- Lista de servicios locales -->
  <section class="py-20 bg-gray-50">
    <div class="container mx-auto px-4 max-w-7xl">
      <div class="text-center mb-12">
        <h2 class="text-3xl font-bold text-electrion-dark mb-4">
          Servicios Disponibles en {lugar.data.name}
        </h2>
        <p class="text-gray-600 max-w-2xl mx-auto text-lg">
          Atendemos emergencias e instalaciones de todas estas categorías
          directamente en su ubicación con garantía y rapidez.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {
          servicios.map((servicio) => (
            <a
              href={`/servicios/${servicio.slug}`}
              class="bg-white rounded-2xl shadow-sm hover:shadow-xl transition-all duration-300 transform md:hover:-translate-y-2 block group border border-gray-100 overflow-hidden flex flex-col h-full"
            >
              {servicio.data.image ? (
                <div class="h-48 overflow-hidden relative">
                  <Image
                    src={servicio.data.image}
                    alt={`${servicio.data.title} en ${lugar.data.name}`}
                    width={400}
                    height={300}
                    format="avif"
                    class="w-full h-full object-cover group-hover:scale-105 transition duration-700 ease-out"
                  />
                  <div class="absolute inset-0 bg-electrion-dark/20 group-hover:bg-transparent transition-colors duration-300" />
                </div>
              ) : (
                <div class="h-48 bg-electrion-blue flex items-center justify-center">
                  <i class="fas fa-bolt text-5xl text-white/20" />
                </div>
              )}

              <div class="p-6 flex flex-col flex-grow">
                <h3 class="text-xl font-bold text-electrion-dark mb-2 group-hover:text-electrion-blue transition-colors duration-200">
                  {servicio.data.title}
                </h3>
                <p class="text-gray-600 mb-4 line-clamp-2 text-sm">
                  {servicio.data.description}
                </p>
                <div class="mt-auto text-electrion-accent font-semibold text-sm flex items-center">
                  Ver opciones en {lugar.data.name}{" "}
                  <i class="fas fa-arrow-right ml-2 group-hover:translate-x-1 transition-transform" />
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-electrion-blue py-12">
    <div class="container mx-auto px-4 text-center">
      <h2 class="text-2xl font-bold text-white mb-4">
        Llegamos rápido a cualquier punto de {lugar.data.name}
      </h2>
      <a
        href="/#contacto"
        class="inline-flex items-center text-white/80 font-bold hover:text-white underline"
      >
        <i class="fas fa-envelope mr-2"></i> Solicitar inspección técnica formal
      </a>
    </div>
  </section>
</Layout>

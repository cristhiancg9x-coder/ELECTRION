---
import "../styles/global.css";

interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-QJE1WHSHSN"
    ></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());

      gtag("config", "G-QJE1WHSHSN");
    </script>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="electricista moquegua, instalaciones eléctricas, mantenimiento eléctrico, automatización PLC, electricidad industrial, electricista urgente, servicios eléctricos"
    />

    <!-- Google Verification -->
    <meta
      name="google-site-verification"
      content="w3ssfq4RyBc5a5N856gWO4jVprcvQ3S4b9bdPdgEU1s"
    />

    <!-- Open Graph para Redes Sociales -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta
      property="og:image"
      content="https://electrion.netlify.app/logo.svg"
    />
    <meta property="og:url" content="https://electrion.netlify.app" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_PE" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta
      name="twitter:image"
      content="https://electrion.netlify.app/logo.svg"
    />

    <!-- Slot para inyectar Schema.org SEO -->
    <slot name="schema" />

    <!-- Favicon y Móviles -->
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <link rel="apple-touch-icon" href="/logo.svg" />

    <!-- Preload -->
    <link
      rel="preload"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Montserrat:wght@600;700;800&display=swap"
      as="style"
    />

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Montserrat:wght@600;700;800&display=swap"
      rel="stylesheet"
    />

    <!-- Font Awesome (Optimización de Carga Diferida LCP/FCP) -->
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin />
    <link
      rel="preload"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/webfonts/fa-solid-900.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />
    <link
      rel="preload"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/webfonts/fa-brands-400.woff2"
      as="font"
      type="font/woff2"
      crossorigin="anonymous"
    />

    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
      media="print"
      onload="this.media='all'"
    />
    <noscript>
      <link
        rel="stylesheet"
        href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css"
      />
    </noscript>
  </head>
  <body class="font-sans bg-gray-50">
    <!-- Header y Navegación -->
    <header class="bg-white shadow-sm sticky top-0 z-50">
      <nav class="container mx-auto px-4 py-3">
        <div class="flex justify-between items-center">
          <!-- Logo -->
          <div class="flex items-center">
            <a href="/" class="flex items-center">
              <img
                src="/logo.svg"
                alt="ELECTRION - Electricistas expertos en Moquegua"
                class="h-12"
                width="48"
                height="48"
                fetchpriority="high"
                loading="eager"
              />
              <span class="ml-3 text-xl font-bold text-electrion-dark"
                >ELECTRION</span
              >
            </a>
          </div>

          <!-- Menú Desktop -->
          <div class="hidden md:flex space-x-8">
            <a
              href="/#inicio"
              class={`font-medium transition-colors ${Astro.url.pathname === "/" ? "text-electrion-blue" : "text-electrion-dark hover:text-electrion-blue"}`}
              >Inicio</a
            >
            <a
              href="/#nosotros"
              class="text-electrion-dark hover:text-electrion-blue font-medium transition-colors"
              >Nosotros</a
            >
            <a
              href="/servicios/"
              class={`font-medium transition-colors ${Astro.url.pathname.includes("/servicios") ? "text-electrion-blue" : "text-electrion-dark hover:text-electrion-blue"}`}
              >Servicios</a
            >
            <a
              href="/#portfolio"
              class="text-electrion-dark hover:text-electrion-blue font-medium transition-colors"
              >Portafolio</a
            >
            <a
              href="/#contacto"
              class="text-electrion-dark hover:text-electrion-blue font-medium transition-colors"
              >Contacto</a
            >
          </div>

          <!-- Botón WhatsApp Desktop -->
          <div class="hidden md:block">
            <a
              href="https://wa.me/51951413458"
              target="_blank"
              class="bg-green-500 text-white px-4 py-2 rounded-lg hover:bg-green-600 transition duration-300"
            >
              <i class="fab fa-whatsapp mr-2"></i>WhatsApp
            </a>
          </div>

          <!-- Menú Mobile -->
          <div class="md:hidden">
            <button
              id="menuBtn"
              class="text-electrion-dark text-2xl"
              aria-label="Abrir menú de navegación"
            >
              <i class="fas fa-bars"></i>
            </button>
          </div>
        </div>

        <!-- Menú Mobile Desplegable -->
        <div
          id="mobileMenu"
          class="hidden md:hidden absolute top-full left-0 w-full bg-white shadow-xl border-t border-gray-100"
        >
          <div class="flex flex-col space-y-4 p-5">
            <a
              href="/#inicio"
              class={`font-medium ${Astro.url.pathname === "/" ? "text-electrion-blue bg-blue-50/50 -mx-5 px-5 py-2 border-l-4 border-electrion-blue" : "text-electrion-dark hover:text-electrion-blue"}`}
              >Inicio</a
            >
            <a
              href="/#nosotros"
              class="text-electrion-dark hover:text-electrion-blue font-medium"
              >Nosotros</a
            >
            <a
              href="/servicios/"
              class={`font-medium ${Astro.url.pathname.includes("/servicios") ? "text-electrion-blue bg-blue-50/50 -mx-5 px-5 py-2 border-l-4 border-electrion-blue" : "text-electrion-dark hover:text-electrion-blue"}`}
              >Servicios</a
            >
            <a
              href="/#portfolio"
              class="text-electrion-dark hover:text-electrion-blue font-medium"
              >Portafolio</a
            >
            <a
              href="/#contacto"
              class="text-electrion-dark hover:text-electrion-blue font-medium"
              >Contacto</a
            >
            <a
              href="https://wa.me/51951413458"
              target="_blank"
              class="bg-green-500 text-white px-4 py-3 text-center rounded-lg font-bold shadow-md hover:bg-green-600 transition mt-2"
            >
              <i class="fab fa-whatsapp mr-2"></i>Contactar por WhatsApp
            </a>
          </div>
        </div>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <!-- Footer -->
    <footer class="bg-electrion-dark text-white py-8">
      <div class="container mx-auto px-4">
        <div class="flex flex-col md:flex-row justify-between items-center">
          <div class="mb-4 md:mb-0 md:w-1/3">
            <div class="flex items-center">
              <img
                src="/logo.svg"
                alt="ELECTRION Soluciones Eléctricas Moquegua"
                class="h-10"
                width="40"
                height="40"
                loading="lazy"
              />
              <span class="ml-3 text-xl font-bold">ELECTRION</span>
            </div>
            <p class="text-gray-400 mt-2">
              Soluciones Eléctricas Profesionales
            </p>
          </div>

          <div class="mb-4 md:mb-0 md:w-1/3 text-center md:text-left">
            <p class="text-white font-bold mb-3 text-lg">
              Cobertura de Servicios
            </p>
            <div class="flex flex-col gap-2 text-sm">
              <a
                href="/electricista-en/moquegua-cercado/"
                class="text-gray-400 hover:text-electrion-accent transition-colors"
                >Electricista en Cercado</a
              >
              <a
                href="/electricista-en/samegua/"
                class="text-gray-400 hover:text-electrion-accent transition-colors"
                >Electricista en Samegua</a
              >
              <a
                href="/electricista-en/san-antonio/"
                class="text-gray-400 hover:text-electrion-accent transition-colors"
                >Electricista en San Antonio</a
              >
              <a
                href="/electricista-en/ilo/"
                class="text-gray-400 hover:text-electrion-accent transition-colors"
                >Electricista en Ilo</a
              >
              <a
                href="/electricista-en/torata/"
                class="text-gray-400 hover:text-electrion-accent transition-colors"
                >Electricista en Torata</a
              >
            </div>
          </div>

          <div
            class="flex flex-col items-center md:items-end md:w-1/3 mt-6 md:mt-0"
          >
            <p class="text-gray-400 mb-2">
              &copy; <span id="year"></span> ELECTRION Soluciones Eléctricas. Todos
              los derechos reservados.
            </p>
            <div class="flex gap-4 mb-2">
              <a
                href="/politica-de-cookies"
                class="text-gray-400 font-medium hover:text-white transition-colors text-sm underline-offset-4 hover:underline"
                >Política de Cookies</a
              >
              <span class="text-gray-600">|</span>
              <p class="text-gray-400 text-sm">Moquegua, Perú</p>
            </div>
          </div>
        </div>
      </div>
    </footer>

    <a
      href="https://wa.me/51951413458"
      target="_blank"
      class="fixed bottom-6 right-6 bg-green-500 text-white w-14 h-14 rounded-full flex items-center justify-center shadow-lg hover:bg-green-600 transition duration-300 z-[60]"
      aria-label="Abrir chat de WhatsApp para asistencia inmediata"
    >
      <i class="fab fa-whatsapp text-2xl"></i>
    </a>

    <!-- Cookie Consent Banner -->
    <div
      id="cookie-banner"
      class="fixed bottom-0 left-0 w-full bg-slate-900 border-t border-slate-700 text-slate-300 transform translate-y-full transition-transform duration-500 z-50 p-4 md:p-6 pb-24 md:pb-6 shadow-2xl"
      inert
    >
      <div
        class="container mx-auto max-w-5xl flex flex-col md:flex-row items-center justify-between gap-6"
      >
        <div class="flex items-start gap-4 flex-1">
          <i
            class="fas fa-cookie-bite text-3xl text-electrion-accent mt-1 hidden md:block"
          ></i>
          <div>
            <h4 class="text-white font-bold mb-1 text-lg">
              Su privacidad es importante
            </h4>
            <p class="text-sm">
              En ELECTRION utilizamos cookies propias y de terceros para
              entender la navegación de los usuarios, analizar métricas y
              mejorar nuestros servicios web. Al hacer clic en "Aceptar",
              consiente el uso de todas las cookies. Puede leer más en nuestra <a
                href="/politica-de-cookies"
                class="text-electrion-accent hover:underline font-semibold"
                >Política de Cookies</a
              >.
            </p>
          </div>
        </div>
        <div class="flex w-full md:w-auto gap-3 shrink-0">
          <button
            id="cookie-reject"
            class="flex-1 md:flex-none px-6 py-2.5 rounded-lg font-bold text-slate-300 border border-slate-600 hover:bg-slate-800 transition-colors"
          >
            Rechazar
          </button>
          <button
            id="cookie-accept"
            class="flex-1 md:flex-none px-6 py-2.5 rounded-lg font-bold text-electrion-dark bg-electrion-accent hover:bg-amber-400 transition-colors shadow-lg"
          >
            Aceptar todas
          </button>
        </div>
      </div>
    </div>

    <!-- JavaScript de Interacción UI -->
    <script>
      // Menú móvil
      const menuBtn = document.getElementById("menuBtn");
      const mobileMenu = document.getElementById("mobileMenu");

      if (menuBtn && mobileMenu) {
        menuBtn.addEventListener("click", function () {
          mobileMenu.classList.toggle("hidden");
          // Cambiar ícono
          const icon = menuBtn.querySelector("i");
          if (mobileMenu.classList.contains("hidden")) {
            if (icon) icon.className = "fas fa-bars";
          } else {
            if (icon) icon.className = "fas fa-times";
          }
        });
      }

      // Cerrar menú móvil al hacer clic en un enlace
      const mobileLinks = document.querySelectorAll("#mobileMenu a");
      mobileLinks.forEach((link) => {
        link.addEventListener("click", function () {
          if (mobileMenu) mobileMenu.classList.add("hidden");
          const icon = menuBtn?.querySelector("i");
          if (icon) icon.className = "fas fa-bars";
        });
      });

      // Cerrar menú móvil al hacer scroll o al tocar fuera (para mejorar UX de header sticky)
      let lastScrollY = window.scrollY;

      function closeMobileMenu() {
        if (mobileMenu && !mobileMenu.classList.contains("hidden")) {
          mobileMenu.classList.add("hidden");
          const icon = menuBtn?.querySelector("i");
          if (icon) icon.className = "fas fa-bars";
        }
      }

      window.addEventListener(
        "scroll",
        function () {
          // Solo cerrar si hay un scroll significativo (más de 10px) para evitar cierres accidentales al tocar
          if (Math.abs(window.scrollY - lastScrollY) > 10) {
            closeMobileMenu();
            lastScrollY = window.scrollY;
          }
        },
        { passive: true },
      );

      // En dispositivos táctiles, el scroll puede no dispararse instantáneamente, cerramos cuando intentan arrastrar
      document.addEventListener(
        "touchmove",
        function (e) {
          // No cerrar si están deslizando DENTRO del menú
          const target = e.target;
          if (
            mobileMenu &&
            target instanceof Node &&
            !mobileMenu.contains(target)
          ) {
            closeMobileMenu();
          }
        },
        { passive: true },
      );
    </script>

    <!-- JavaScript de Interacción UI y Cookies -->
    <script is:inline>
      document.addEventListener("DOMContentLoaded", () => {
        // --- LÓGICA DE ACTUALIZACIÓN DEL AÑO EN FOOTER ---
        const yearSpan = document.getElementById("year");
        if (yearSpan) {
          yearSpan.textContent = new Date().getFullYear();
        }

        // --- LÓGICA DEL BANNER DE COOKIES ---
        const cookieBanner = document.getElementById("cookie-banner");
        const acceptBtn = document.getElementById("cookie-accept");
        const rejectBtn = document.getElementById("cookie-reject");

        // Chequear si ya hay consentimiento
        const cookieConsent = localStorage.getItem("electrion_cookie_consent");

        if (!cookieConsent) {
          // Mostrar banner con ligera animación de subida
          setTimeout(() => {
            cookieBanner.classList.remove("translate-y-full");
            cookieBanner.removeAttribute("inert");
          }, 1000);
        }

        // Función para ocultar el banner de forma suave
        const hideBanner = () => {
          cookieBanner.setAttribute("inert", "");
          cookieBanner.classList.add("translate-y-full");
          setTimeout(() => {
            cookieBanner.style.display = "none";
          }, 500);
        };

        // Acciones principales
        if (acceptBtn) {
          acceptBtn.addEventListener("click", () => {
            localStorage.setItem("electrion_cookie_consent", "accepted");
            // Aquí se inicializarían los scripts de Analytics si existieran
            hideBanner();
          });
        }

        if (rejectBtn) {
          rejectBtn.addEventListener("click", () => {
            localStorage.setItem("electrion_cookie_consent", "rejected");
            // Aquí se bloquearían las cookies de terceros
            hideBanner();
          });
        }
        const observerOptions = {
          root: null,
          rootMargin: "0px",
          threshold: 0.15,
        };

        const observer = new IntersectionObserver((entries, observer) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("opacity-100", "translate-y-0");
              entry.target.classList.remove("opacity-0", "translate-y-8");
              observer.unobserve(entry.target);
            }
          });
        }, observerOptions);

        document.querySelectorAll(".reveal-on-scroll").forEach((el) => {
          observer.observe(el);
        });
      });
    </script>
  </body>
</html>
